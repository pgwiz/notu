# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=mysql+pymysql://notu:notu123@localhost:3306/notu

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=notu
MYSQL_PASSWORD=notu123
MYSQL_DATABASE=notu
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=rootpassword

# S3 Configuration (optional)
# For AWS S3:
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# For Scaleway Object Storage:
# S3_BUCKET_NAME=your-scaleway-bucket
# S3_REGION=fr-par
# S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
# AWS_ACCESS_KEY_ID=your-scaleway-access-key
# AWS_SECRET_ACCESS_KEY=your-scaleway-secret-key

# File Upload Settings
MAX_CONTENT_LENGTH=104857600  # 100MB
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,jpg,jpeg,png,gif

# Storage Settings
STORAGE_LOCAL_ROOT=./storage/local
STORAGE_BUCKET_ROOT=storage/bucket
ACTIVE_STORAGE_BACKEND=s3

# Security Settings
WTF_CSRF_ENABLED=true
SESSION_COOKIE_SECURE=false  # Set to true in production with HTTPS

# Theme Settings
DEFAULT_THEME=green-black

# Pagination
DOCUMENTS_PER_PAGE=20

# Sync Settings
SYNC_DRY_RUN=true

# Antivirus Settings (optional)
ANTIVIRUS_ENABLED=false
ANTIVIRUS_PATH=/usr/bin/clamscan

# Registration Settings
ALLOW_REGISTRATION=false
